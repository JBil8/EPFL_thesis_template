@article{bilotto_three_,
	title = {{THREE} {REGIMES} {OF} {FLUID}-{MEDIATED} {IMPACT}},
	abstract = {We present a theory for early stages of fluid-mediated impact against a rigid flat surface. This framework encompasses spherical incompressible impactors, both solid ones (regardless of stiffness) and liquid ones (droplets), mediating fluid being either a liquid or a gas. The phase preceding contact between surface and impactor is characterized by fluid viscous response in a thin layer between the impactor and the rigid surface, which can be understood using Reynolds lubrication equation. Several cases of dimple formation and bubble entrapment have been reported in literature, as well as two limit regimes, one in which internal forces dominate over inertial ones (for impact of hard solids at low velocities) and another one where the roles are swapped (characteristic of air-mediated droplet impact at low Mach number). Recently, experiments spanned these two regimes and the transition between them using soft solids impacting a flat surface at atmospheric pressure. We pose that the transition happens not suddenly but smoothly through an intermediate regime that combines traits of both aforementioned ones, visualized for the first time in air-mediated impacts of soft solids. A salient feature of this transition regime is the retardation of impact, achieving the maximum radius of entrapped air bubble. There exist two relevant time scales to this phenomenon: the characteristic time it takes information to propagate over the region where viscous pressures build up and the characteristic time of projectile advection. We outline how the ratio between these two timescales discriminates the three possible regimes. We substantiate our findings with both experimental results and numerical fluid-solid simulations.},
	language = {en},
	author = {Bilotto, Jacopo and Garcia-Suarez, Joaquin and Subhash, Ghatu and Molinari, Jean-François and Lecampion, Brice and Eddebbarh, Youssef and Kolinski, John},
}
