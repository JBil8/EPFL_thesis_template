	issn = {0022-1120, 1469-7645},
	url = {https://www.cambridge.org/core/journals/journal-of-fluid-mechanics/article/generalized-model-for-dense-axisymmetric-grains-flow-with-orientational-diffusion/F4FD946E0D6843B1244B389E5A0FC2A6},
	doi = {10.1017/jfm.2022.44},
	abstract = {, 
