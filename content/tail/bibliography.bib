@article{zhou_steady_2007,
	title = {Steady {States} and {Dynamics} of \$2-{D}\$ {Nematic} {Polymers} {Driven} by an {Imposed} {Weak} {Shear}},
	volume = {5},
	issn = {1539-6746, 1945-0796},
	url = {https://projecteuclid.org/journals/communications-in-mathematical-sciences/volume-5/issue-1/Steady-States-and-Dynamics-of-2-D-Nematic-Polymers-Driven/cms/1175797624.full},
	abstract = {We study the \$2-D\$ Smoluchowski equation governing the evolution of orientational distribution of rodlike molecules under an imposed weak shear. We first recover the well-known isotropic-to-nematic phase transition result: in the absence of flow the isotropic-nematic phase transition occurs at \$U =2\$ where \$U\$ is the normalized polymer concentration, representing the intensity of the Maier-Saupe interaction potential. Then we show that in the presence of an imposed weak shear there is a threshold \$(U{\textbackslash}sb 0{\textbackslash}approx 2:41144646)\$ for \$U\$: When \$U {\textless} U{\textbackslash}sb 0\$, steady state solution exists; otherwise there is no steady state. Furthermore, we carry out multi-scale asymptotic anlaysis to study the slow time evolution driven by the weak shear. It is revealed that, to the leading order, the order parameter of the orientational distribution is invariant with respect to time whereas the angular velocity of the director is position-dependent. When \$U {\textless} U{\textbackslash}sb 0\$, the director of the orientational distribution converges to a stable steady state position; when \$U {\textgreater} U{\textbackslash}sb 0\$, the angular velocity of the director is always positive and the orientational distribution will not reach a steady state. Finally, the effect of weak shear on the phase diagram is investigated. It is found that the phase relation under weak shear can be obtained from the pure nematic phase relation through a simple algebraic transformation.},
	number = {1},
	urldate = {2025-06-05},
	journal = {Communications in Mathematical Sciences},
	publisher = {International Press of Boston},
	author = {Zhou, Hong and Wang, Hongyun},
	month = mar,
	year = {2007},
	keywords = {Kinetic theory, Maier-Saupe potential, Nematic polymers, Perturbation analysis, Shear flow, diffusion, non spherical particles},
	pages = {113--132},
}

