@article{houlsby_potential_2009b,
	title = {Potential particles: a method for modelling non-circular particles in {DEM}},
	volume = {36},
	issn = {0266-352X},
	shorttitle = {Potential particles},
	url = {https://www.sciencedirect.com/science/article/pii/S0266352X09000469},
	doi = {10.1016/j.compgeo.2009.03.001},
	abstract = {Options for defining non-circular (or non-spherical) particles in DEM codes are briefly reviewed before introducing a new concept: potential particles. This method can be used to define convex particles with a wide variety of shapes, from almost polygonal to circular. It is readily applicable in both two and three dimensions. Although contact detection and overlap calculations are not as fast as for circular particles, they can nevertheless be made sufficiently simple and fast for implementation in DEM codes.},
