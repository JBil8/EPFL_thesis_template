@article{garcia-suarez_matter_2026,
	title = {A {Matter} of {Shape}: {Contact} {Area} {Optimization} in {Soft} {Lubricated} {Impact}},
	volume = {74},
	issn = {1573-2711},
	shorttitle = {A {Matter} of {Shape}},
	url = {https://doi.org/10.1007/s11249-026-02108-1},
	doi = {10.1007/s11249-026-02108-1},
	abstract = {We study the fluid-mediated impact of a deformable axisymmetric object against a rigid substrate, focusing on how its shape influences contact formation. For low approach velocities and large Stokes numbers, we show that sharper profiles (e.g., conical) maximize contact at the center and avoid fluid entrapment, while blunter ones form central dimples that trap bubbles. We also find that the resulting pressure distributions in the presence of thin viscous films can be predicted remarkably well by classical (dry) contact mechanics. These findings reveal shape as a design parameter for contact optimization in soft matter, adhesion, and elastohydrodynamics. Finally, we also theorize the possibility of a mechanical equivalence between shape and approach velocity.},
	language = {en},
	number = {1},
	urldate = {2026-03-14},
	journal = {Tribology Letters},
	author = {Garcia-Suarez, Joaquin},
	month = jan,
	year = {2026},
	keywords = {Contact area, Elastohydrodynamic lubrication, Geometry, Indentation, Soft solid},
	pages = {15},
}

@book{gennes_physics_1995,
	address = {Oxford, New York},
	edition = {Second Edition, Second Edition},
	series = {International {Series} of {Monographs} on {Physics}},
	title = {The {Physics} of {Liquid} {Crystals}},
	isbn = {978-0-19-851785-6},
	abstract = {This new edition of this classic text on condensed matter physics includes the great advances that have taken place since its first publication in 1974. New chapters describe the main types and properties of liquid crystals in terms of the new phases discovered since the middle of the 1970's, and advances in the understanding of local order and the nature of the isotropic to nematic transition. There is an extensive discussion of the symmetry, and macroscopic and dynamic properties of smectics and columnar phases, and their defects, illustrated with numerous descriptions of experimental arrangements. The final chapter is devoted to phase transitions in smectics, including the celebrated analogy between Smectic A and superconductors. Throughout the book there is an emphasis on order-of-magnitude considerations. Its topicality and breadth of coverage will ensure that The Physics of Liquid Crystals remains an indispensable guide for students and researchers alike.
               
               
                
              ,  
               This new edition of this classic text on condensed matter physics includes the great advances that have taken place since its first publication in 1974. New chapters describe the main types and properties of liquid crystals in terms of the new phases discovered since the middle of the 1970's, and advances in the understanding of local order and the nature of the isotropic to nematic transition. There is an extensive discussion of the symmetry, and macroscopic and dynamic properties of smectics and columnar phases, and their defects, illustrated with numerous descriptions of experimental arrangements. The final chapter is devoted to phase transitions in smectics, including the celebrated analogy between Smectic A and superconductors. Throughout the book there is an emphasis on order-of-magnitude considerations. Its topicality and breadth of coverage will ensure that The Physics of Liquid Crystals remains an indispensable guide for students and researchers alike.},
	publisher = {Oxford University Press},
	author = {Gennes, P. G. de and Prost, J. and Gennes, P. G. de and Prost, J.},
	month = apr,
	year = {1995},
}

