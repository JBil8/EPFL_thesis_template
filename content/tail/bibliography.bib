@article{borzsonyi_granular_2013,
	title = {Granular materials composed of shape-anisotropic grains},
	volume = {9},
	issn = {1744-6848},
	url = {https://pubs.rsc.org/en/content/articlelanding/2013/sm/c3sm50298h},
	doi = {10.1039/C3SM50298H},
	abstract = {Granular physics has made considerable progress during the past decades in the understanding of static and dynamic properties of large ensembles of interacting macroscopic particles, including the modeling of phenomena like jamming, segregation and pattern formation, the development of related industrial applications or traffic flow control. The specific properties of systems composed of shape-anisotropic (elongated or flattened) particles have attracted increasing interest in recent years. Orientational order and self-organization are among the characteristic phenomena that add to the special features of granular matter of spherical or irregularly shaped particles. An overview of this research field is given.},
