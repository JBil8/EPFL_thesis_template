@article{vescovi_simple_2024a,
	title = {Simple generalization of kinetic theory for granular flows of nonspherical, oriented particles},
	volume = {9},
	url = {https://link.aps.org/doi/10.1103/PhysRevFluids.9.L012301},
	doi = {10.1103/PhysRevFluids.9.L012301},
	abstract = {We generalize kinetic theory of inelastic spheres to uniaxial, nonspherical grains by including the orientational tensor as a state variable. The theory has three phenomenological parameters, with one parameter to account for the dependency of the stresses on the orientation, which is exactly one for frictionless cylinders, and the other two parameters to predict the orientational tensor. We model the competition between the alignment induced by shearing and the misalignment due to collisions in the evolution law for the orientational tensor. The theory can predict a significant reduction in the viscosity in response to alignment measured in discrete simulations of homogeneous shear flows of prolate and oblate frictionless cylinders.},
	number = {1},
	urldate = {2025-07-30},
	journal = {Physical Review Fluids},
	publisher = {American Physical Society},
	author = {Vescovi, Dalila and Nadler, Ben and Berzi, Diego},
	month = jan,
	year = {2024},
	pages = {L012301},
}

